# ============================================================
# Arkon — Local development environment
# cp .env.local.example .env.local
# Requires: PostgreSQL, Redis, MinIO running on localhost
# ============================================================

# --- PostgreSQL ---
DATABASE_URL=postgresql+asyncpg://arkon:arkon_secret@localhost:5432/arkon

# --- Auth (JWT) ---
SECRET_KEY=change-me-to-a-random-secret-string

# --- MCP token hashing ---
# HMAC pepper for hashing MCP bearer tokens at rest. Generate with:
# python -c "import secrets; print(secrets.token_urlsafe(32))"
# Rotating this value invalidates EVERY existing MCP token — set once and keep stable.
MCP_TOKEN_PEPPER=change-me-to-a-random-pepper

# --- Default Admin Account ---
DEFAULT_ADMIN_EMAIL=admin@arkon.local
DEFAULT_ADMIN_PASSWORD=admin123

# --- MinIO ---
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_BUCKET=arkon-files
MINIO_SECURE=false
MINIO_PRESIGN_EXPIRY_HOURS=24

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
WORKER_MAX_JOBS=3
WORKER_JOB_TIMEOUT=600

# --- MRP Pipeline ---
# Dev default: auto-approve plans so wiki content appears immediately after upload.
# Production should set this to false and ship a frontend plan-approval UX.
MRP_AUTO_APPROVE_PLAN=true

# --- Upload limits ---
# Reject /sources/upload + workspace/contribution uploads above this size. 0 = unlimited.
MAX_SOURCE_FILE_MB=100

# --- CORS ---
CORS_ORIGINS=*

# --- Frontend ---
NEXT_PUBLIC_API_URL=http://localhost:5055
NEXT_TELEMETRY_DISABLED=1
