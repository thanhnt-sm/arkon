# ============================================================
# Arkon — Local development environment
# cp .env.local.example .env.local
# Requires: PostgreSQL, Redis, MinIO running on localhost
# ============================================================

# --- PostgreSQL ---
DATABASE_URL=postgresql+asyncpg://arkon:arkon_secret@localhost:5432/arkon

# --- Auth (JWT) ---
SECRET_KEY=change-me-to-a-random-secret-string

# --- Default Admin Account ---
DEFAULT_ADMIN_EMAIL=admin@arkon.local
DEFAULT_ADMIN_PASSWORD=admin123

# --- MinIO ---
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_BUCKET=arkon-files
MINIO_SECURE=false
MINIO_PRESIGN_EXPIRY_HOURS=24

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
WORKER_MAX_JOBS=3
WORKER_JOB_TIMEOUT=600

# --- CORS ---
CORS_ORIGINS=*

# --- Frontend ---
NEXT_PUBLIC_API_URL=http://localhost:5055
NEXT_TELEMETRY_DISABLED=1
