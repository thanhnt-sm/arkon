-acl Safe_ports port 80      # http
-acl Safe_ports port 443     # https
-acl CONNECT method CONNECT
-
-# -----------------------------------------------------------------------
-# WHITELISTED DOMAINS — Minimal surface, explicitly justified
-# -----------------------------------------------------------------------
-# OpenAI Chat + Embedding API
-acl whitelisted_domains dstdomain api.openai.com
-# OpenRouter API
-acl whitelisted_domains dstdomain openrouter.ai
-# Anthropic Claude API
-acl whitelisted_domains dstdomain api.anthropic.com
-# Google Gemini API (LLM, embedding, vision/OCR) — only this subdomain, NOT .googleapis.com wildcard
-acl whitelisted_domains dstdomain generativelanguage.googleapis.com
-# Google OAuth token exchange (for Gemini service-account auth)
-acl whitelisted_domains dstdomain oauth2.googleapis.com
-# Mistral LLM API
-acl whitelisted_domains dstdomain api.mistral.ai
-# Cohere LLM/embed/rerank API
-acl whitelisted_domains dstdomain api.cohere.ai
-acl whitelisted_domains dstdomain api.cohere.com
-# Groq inference API
-acl whitelisted_domains dstdomain api.groq.com
-# DO NOT add .googleapis.com or .google.com — covers analytics/firebase/drive/etc.
-# To add a new provider: append a specific dstdomain line and document the justification.
-
-# Local LLM server (LM Studio on host) — accessible via IP or Docker hostname
-acl local_llm_ip dst 192.168.1.11
-acl local_llm_host dstdomain host.docker.internal
-acl local_llm_port port 1234
-
-# -----------------------------------------------------------------------
-# ACCESS RULES
-# -----------------------------------------------------------------------
-# Exception for local LLM server (port 1234 not in Safe_ports, must come first)
-http_access allow localnet local_llm_ip local_llm_port
-http_access allow localnet local_llm_host local_llm_port
-
-# Deny requests to certain unsafe ports
-http_access deny !Safe_ports
-
-# Deny CONNECT to other than secure SSL ports
-http_access deny CONNECT !SSL_ports
-
-# Only allow cachemgr access from localhost
-http_access allow localhost manager
-http_access deny manager
-
-# ALLOW TRAFFIC TO WHITELISTED DOMAINS ONLY
-http_access allow localnet whitelisted_domains
-http_access allow localhost whitelisted_domains
-
-# AND FINALLY DENY ALL OTHER ACCESS TO THIS PROXY
-http_access deny all
-
-# No caching for a secure API proxy
-cache deny all
