-            1) echo "status=FAIL" >> "$GITHUB_OUTPUT" ;;
-            *) echo "status=WARN" >> "$GITHUB_OUTPUT" ;;
-          esac
-          exit 0  # don't fail the workflow on audit findings; we open an issue instead
-
-      - name: Categorize conflicts
-        id: categorize
-        if: steps.sync.outputs.up_to_date != 'true'
