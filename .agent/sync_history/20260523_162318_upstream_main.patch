-            echo "❌ no patch archived; aborting audit"
-            exit 2
-          fi
-          echo "patch=$PATCH" >> "$GITHUB_OUTPUT"
-          echo "up_to_date=false" >> "$GITHUB_OUTPUT"
-
-      - name: Run security audit
-        id: audit
-        if: steps.sync.outputs.up_to_date != 'true'
-        run: |
-          set +e
-          AUDIT_PATCH_FILE="${{ steps.sync.outputs.patch }}" \
