+                progress_activity
+              </span>
+            ) : (
+              <span className="material-symbols-outlined text-sm">
+                {effectiveMode === "direct" ? "add" : "send"}
+              </span>
+            )}
+            {effectiveMode === "direct" ? "Create page" : "Submit proposal"}
+          </Button>
+        </DialogFooter>
+      </DialogContent>
+    </Dialog>
+  );
+}
