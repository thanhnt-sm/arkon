-name: upstream-audit
-
-# Weekly upstream sync audit — dry-run only, never merges.
-# - Fetches upstream, archives the diff, runs the security audit + conflict
-#   categorization, uploads artifacts, and (on WARN/FAIL) opens a GitHub
-#   issue. Idempotent: one issue per upstream SHA.
-
-on:
-  schedule:
-    # Monday 08:00 Asia/Saigon = Monday 01:00 UTC.
-    - cron: "0 1 * * 1"
-  workflow_dispatch:
-    inputs:
-      upstream_url:
-        description: "Override upstream remote URL (optional)"
-        required: false
-        type: string
-
-permissions:
-  contents: read
-  issues: write
-
-jobs:
-  audit:
-    runs-on: ubuntu-latest
-    timeout-minutes: 15
-    env:
-      UPSTREAM_REF: upstream/main
-
-    steps:
-      - name: Checkout
-        uses: actions/checkout@v4
-        with:
-          fetch-depth: 0
-
-      - name: Install tools
-        run: |
-          sudo apt-get update -y
-          sudo apt-get install -y jq inotify-tools
-          python3 -m pip install --user pip-audit
-
-      - name: Configure upstream remote
-        env:
-          UPSTREAM_URL: ${{ inputs.upstream_url || secrets.UPSTREAM_URL }}
-        run: |
-          if [ -z "${UPSTREAM_URL:-}" ]; then
-            echo "❌ UPSTREAM_URL secret not configured."
-            echo "   Add it via: Settings → Secrets and variables → Actions"
-            exit 1
-          fi
-          git remote remove upstream 2>/dev/null || true
-          git remote add upstream "$UPSTREAM_URL"
-          git config user.email "ci@example.com"
-          git config user.name  "upstream-audit-ci"
-
-      - name: Dry-run sync (fetch + archive)
-        id: sync
-        run: |
-          set +e
-          SYNC_MODE=dryrun bash .agent/workflows/safe_sync.sh upstream main 2>&1 \
-            | tee /tmp/sync.log
-          rc=$?
-          if [ "$rc" -eq 0 ] && grep -q "Already up to date" /tmp/sync.log; then
-            echo "up_to_date=true" >> "$GITHUB_OUTPUT"
-            exit 0
-          fi
-          # Extract archived patch path from sync output.
-          PATCH=$(grep -E "^PATCH_FILE=" /tmp/sync.log | tail -1 | cut -d= -f2)
