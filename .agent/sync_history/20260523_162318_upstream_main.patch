-ROW=$(echo "$OVERLAY_OUT" | jq -r '.[] | select(.file=="shared-a.ts") | .category')
-[ "$ROW" = "security-risk" ] \
-  && ok "security overlay overrides to security-risk" \
-  || no "overlay failed, got $ROW"
